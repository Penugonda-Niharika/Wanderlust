<% layout("/layouts/boilerplate") %>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet/dist/leaflet.css"
/>

<div class="container mt-4">
  <div class="row">
    <div class="col-lg-6 offset-lg-3">
      <h2 class="mb-4 text-center"><%= listing.title %></h2>

      <div class="card show-card">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top show-img"
          alt="listings_img"
        />

        <div class="card-body p-3">
          <p>
            <i>
              <strong>
                Owned By @<%= listing.owner ? listing.owner.username : "Unknown user" %>
              </strong>
            </i>
          </p>

          <p class="card-text">
            <strong>Price:</strong>
            &#8377; <%= (listing.price || 0).toLocaleString("en-IN") %>
          </p>

          <p class="card-text">
            <strong>Location:</strong> <%= listing.location %>
          </p>

          <p class="card-text">
            <strong>Country:</strong> <%= listing.country %>
          </p>

          <p class="card-text">
            <strong>Description:</strong>
            <%= listing.description %>
          </p>
        </div>
      </div>

      <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
        <div class="btns d-flex gap-2 mt-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">
            Edit
          </a>

          <form
            action="/listings/<%= listing._id %>?_method=DELETE"
            method="post"
          >
            <button class="btn btn-dark">Delete</button>
          </form>
        </div>
      <% } %>

      

      <% if (currUser) { %>
        <hr class="my-4" />

        <h4>Leave a Review</h4>

        <form
          action="/listings/<%= listing._id %>/reviews"
          class="needs-validation"
          novalidate
          method="post"
        >
          <div class="mt-3">
            <label for="rating" class="form-label">Rating</label>

            <fieldset class="starability-slot">
              <input
                type="radio"
                id="no-rate"
                class="input-no-rate"
                name="review[rating]"
                value="1"
                checked
                aria-label="No rating."
              />

              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>

              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>

              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>

              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>

              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>

            <textarea
              name="review[comment]"
              id="comment"
              rows="5"
              class="form-control"
              required
            ></textarea>

            <div class="invalid-feedback">Please add some comments</div>
          </div>

          <button class="btn btn-outline-dark mb-3">Submit</button>
        </form>
      <% } %>

      <% if (listing.reviews && listing.reviews.length > 0) { %>
        <hr class="my-4" />

        <h5>All Reviews</h5>

        <div class="row">
          <% for (let review of listing.reviews) { %>
            <div class="col-md-6 mb-3">
              <div class="card h-100 p-3">
                <div class="card-body">
                  <h6 class="card-title">
                    @<%= review.author ? review.author.username : "Anonymous" %>
                  </h6>

                  <p
                    class="starability-result card-text"
                    data-rating="<%= review.rating %>"
                  >
                    Rated: <%= review.rating %> stars
                  </p>

                  <p class="card-text"><%= review.comment %></p>

                  <form
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="post"
                  >
                    <button class="btn btn-sm btn-dark">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
      <hr class="my-4" />

      <h4>Where you'll be</h4>
      <div id="map"></div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
  const listingGeoJSON = <%- JSON.stringify({
    type: "Feature",
    properties: {
      title: listing.title,
      location: listing.location,
    },
    geometry: listing.geometry || {
      type: "Point",
      coordinates: [77.209, 28.6139],
    },
  }) %>;

  const coords = listingGeoJSON.geometry.coordinates;

  const map = L.map("map").setView([coords[1], coords[0]], 13);

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: "&copy; OpenStreetMap contributors",
    maxZoom: 19,
  }).addTo(map);

  const homeIcon = L.divIcon({
    html: `<div class="home-marker"></div>`,
    className: "",
    iconSize: [40, 40],
    iconAnchor: [20, 40],
    popupAnchor: [0, -40],
  });

  L.geoJSON(listingGeoJSON, {
    pointToLayer: function (feature, latlng) {
      return L.marker(latlng, { icon: homeIcon });
    },
    onEachFeature: function (feature, layer) {
      layer.bindPopup(`
        <div class="map-popup">
          <h5>${feature.properties.title}</h5>
          <p>📍 ${feature.properties.location}</p>
        </div>
      `);
    },
  }).addTo(map);
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.querySelector(".needs-validation");

    if (!form) return;

    form.addEventListener("submit", function (event) {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }

      form.classList.add("was-validated");
    });
  });
</script>